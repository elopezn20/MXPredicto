# Supabase (get from your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# Football-data.org (https://www.football-data.org — free tier: 10 req/min)
FOOTBALL_DATA_API_KEY=your-api-key

# Resend (https://resend.com — free tier: 3 000 emails/month)
RESEND_API_KEY=your-api-key
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App config
NEXT_PUBLIC_APP_NAME="Polla Mundial 2026"
NEXT_PUBLIC_APP_URL=http://localhost:3000
